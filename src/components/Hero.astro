---
const now = new Date();
const bookingDate = new Date(now.getFullYear(), now.getMonth() + 2, 1);
const bookingMonth = bookingDate.toLocaleString('en-US', { month: 'long', year: 'numeric' });
---

<section class="bg-cream">
  <div class="max-w-site mx-auto px-6 md:px-12 py-24 md:py-40">
    <div
      class="mb-5"
      data-sal="fade-up"
      data-sal-duration="500"
    >
      <span class="inline-flex items-center gap-2 bg-forest-pale text-forest text-[12px] font-semibold tracking-wide px-3.5 py-1.5 rounded-full border border-forest/20">
        <span class="w-1.5 h-1.5 rounded-full bg-forest animate-pulse inline-block flex-shrink-0"></span>
        Now Booking {bookingMonth}
      </span>
    </div>

    <p
      class="text-[11px] font-semibold text-forest tracking-[0.12em] uppercase mb-6"
      data-sal="fade-up"
      data-sal-duration="500"
      data-sal-delay="50"
    >
      Boutique Shopify Development Studio · US-Based
    </p>

    <h1
      class="font-serif text-[52px] md:text-[72px] lg:text-[88px] leading-[1.03] max-w-[820px] mb-10 tracking-[-0.06em]"
      data-sal="fade-up"
      data-sal-duration="500"
      data-sal-delay="100"
      data-hero-h1
    >
      Shopify development with an operator's eye.
    </h1>

    <p
      class="text-[17px] leading-[1.78] text-ui-body max-w-[520px] mb-8"
      data-sal="fade-up"
      data-sal-duration="500"
      data-sal-delay="200"
    >
      Lindahl Studios is a boutique Shopify development studio that works with a
      select number of brands. Not everyone. We go deep with the stores we take
      on: custom builds, CRO-focused UI/UX, and ecommerce strategy grounded in
      more than a decade of development experience.
    </p>

    <p
      class="text-[17px] leading-[1.78] text-ui-body max-w-[520px] mb-10"
      data-sal="fade-up"
      data-sal-duration="500"
      data-sal-delay="300"
    >
      The difference? I run my own bootstrapped ecommerce brand on Shopify. I track the same
      metrics you do: contribution margin, LTV, CAC, MER. I bring that operator perspective
      to every project. Your store deserves more than just code. It deserves
      someone who understands the business behind it.
    </p>

    <div
      class="flex flex-wrap gap-4"
      data-sal="fade-up"
      data-sal-duration="500"
      data-sal-delay="400"
    >
      <a
        href="/contact"
        class="group inline-block px-8 py-3.5 bg-forest text-white rounded-lg text-[15px] font-semibold hover:bg-forest-light transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-forest focus-visible:ring-offset-2"
      >
        Start a Project <span class="inline-block transition-transform duration-200 ease-out group-hover:translate-x-1">→</span>
      </a>
      <a
        href="#work"
        class="inline-block px-8 py-3.5 border-[1.5px] border-ui-border-md text-charcoal rounded-lg text-[15px] font-semibold hover:border-ui-faint transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-charcoal/40 focus-visible:ring-offset-2"
      >
        See Our Work
      </a>
    </div>
  </div>
</section>

<script>
  // Cinematic word-reveal entrance for the hero h1.
  // sal.js (fade-up) hides the h1 via opacity:0. We intercept via MutationObserver
  // when sal adds "sal-animate", remove it immediately, kill sal's opacity rule,
  // then run our clip-mask word reveal using the Web Animations API.
  (function () {
    if (typeof window === 'undefined') return;

    const h1 = document.querySelector('[data-hero-h1]') as HTMLElement | null;
    if (!h1) return;

    // Respect reduced motion — let sal.js handle a simple fade instead
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const EASING = 'cubic-bezier(0.16, 1, 0.3, 1)'; // ease-out-quart
    const WORD_DURATION = 780;
    const WORD_STAGGER = 52;
    const WORD_START_DELAY = 100; // slight offset after badge/eyebrow sal entrance

    function runWordReveal() {
      const text = h1!.textContent!.trim();
      const words = text.split(/\s+/);

      // Clear, then rebuild with per-word clip containers
      h1!.innerHTML = '';
      // h1 container is now visible (opacity removed by removeAttribute below);
      // words are geometrically hidden inside overflow:hidden until they slide up

      words.forEach((word, i) => {
        // Outer: the clipping boundary — overflow:hidden hides word below the baseline
        const outer = document.createElement('span');
        outer.style.cssText =
          'display:inline-block;overflow:hidden;vertical-align:bottom;' +
          // Generous bottom padding so descenders (y, g, p) clear the clip at large sizes
          'padding-bottom:0.2em;margin-bottom:-0.2em';

        // Inner: the word itself — starts below the clip, slides upward
        const inner = document.createElement('span');
        inner.style.display = 'inline-block';
        inner.textContent = word;

        outer.appendChild(inner);
        h1!.appendChild(outer);

        // Preserve inter-word spaces
        if (i < words.length - 1) {
          h1!.appendChild(document.createTextNode(' '));
        }

        // Web Animations API — translateY only (GPU-composited, no layout thrash)
        inner.animate(
          [
            { transform: 'translateY(110%)' },
            { transform: 'translateY(0%)' },
          ],
          {
            duration: WORD_DURATION,
            delay: WORD_START_DELAY + i * WORD_STAGGER,
            easing: EASING,
            fill: 'both', // holds translateY(110%) during delay so it stays clipped
          }
        );
      });
    }

    // Watch for sal.js adding "sal-animate" to take over the entrance
    const observer = new MutationObserver(() => {
      if (h1!.classList.contains('sal-animate')) {
        // Intercept: remove sal's class + css rule before any transition fires
        h1!.classList.remove('sal-animate');
        h1!.style.transition = 'none';
        h1!.removeAttribute('data-sal'); // kills sal.css opacity:0 rule
        h1!.style.opacity = '1';         // container visible; words still clipped
        observer.disconnect();
        runWordReveal();
      }
    });

    observer.observe(h1, { attributes: true, attributeFilter: ['class'] });
  })();
</script>
