---
const steps = [
  {
    number: '01',
    title: 'Discovery Call',
    body: 'We start with a no-pressure conversation to understand your business, your goals, and what you actually need built. No proposals before we talk.',
  },
  {
    number: '02',
    title: 'Scope & Proposal',
    body: "I put together a clear scope of work with defined deliverables, timeline, and pricing. No vague estimates. You know exactly what you're getting.",
  },
  {
    number: '03',
    title: 'Project Setup',
    body: "For larger engagements, I set up a shared Basecamp project so you have full visibility into tasks, timelines, and progress. No wondering what's happening.",
  },
  {
    number: '04',
    title: 'Build & Ship',
    body: 'We build iteratively, shipping features and adjustments continuously with full backups in place via GitHub. You see progress, not just a big reveal at the end.',
  },
  {
    number: '05',
    title: 'Keep Pushing',
    body: 'Launch is just the beginning. We stay embedded, proactively surfacing CRO wins, UI improvements, and ideas that move the needle for your business.',
  },
];
---

<section id="process" class="bg-cream">
  <div class="max-w-site mx-auto px-6 md:px-12 py-20 md:py-28">

    <div class="max-w-[680px] mb-14 md:mb-20">
      <p
        class="text-[11px] font-semibold text-forest tracking-[0.12em] uppercase mb-3"
        data-sal="fade-up"
        data-sal-duration="500"
      >
        The Process
      </p>
      <h2
        class="font-serif text-[30px] md:text-[52px] leading-[1.1] mb-3"
        data-sal="fade-up"
        data-sal-duration="500"
        data-sal-delay="80"
      >
        How we work
      </h2>
      <p
        class="text-[15px] text-ui-muted leading-relaxed"
        data-sal="fade-up"
        data-sal-duration="500"
        data-sal-delay="160"
      >
        Calm over chaos. Every project follows the same clear process so you always know what's happening and what's coming next.
      </p>
    </div>

    <!-- Steps — editorial rows with large serif numbers as visual anchor -->
    <div class="border-t border-forest/[0.1]">
      {steps.map((step, i) => (
        <div
          class="border-b border-forest/[0.1] py-10 md:py-12 grid grid-cols-[72px_1fr] md:grid-cols-[128px_1fr] gap-8 md:gap-14 items-start"
          data-sal="fade-up"
          data-sal-duration="500"
          data-sal-delay={String(i * 80)}
        >

          {/* Step number — large decorative serif, not interactive */}
          <div class="select-none pointer-events-none" aria-hidden="true">
            <span
              class="font-serif leading-[0.9] text-forest/[0.15]"
              style="font-size: clamp(48px, 6vw, 80px);"
            >
              {step.number}
            </span>
          </div>

          {/* Content */}
          <div class="pt-1 md:pt-2">
            <h3 class="font-serif text-[22px] md:text-[26px] leading-[1.15] tracking-[-0.02em] mb-3">
              {step.title}
            </h3>
            <p class="text-[14px] leading-[1.78] text-ui-body max-w-[480px]">
              {step.body}
            </p>
          </div>

        </div>
      ))}
    </div>

  </div>
</section>
