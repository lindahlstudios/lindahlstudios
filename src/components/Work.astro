---
const projects = [
  {
    client: 'Aviator Nation RIDE',
    type: 'Shopify Plus · Full Redesign',
    work: [
      'Led total website redesign',
      'Custom metaobject features',
      'UX overhaul',
    ],
    url: 'https://aviatornationride.com',
    logoFile: 'aviator-nation-ride.svg',
    screenshotFile: 'aviatornationride.com.avif',
  },
  {
    client: 'Aviator Nation',
    type: 'Shopify Plus · Theme & CRO',
    work: [
      'Regular theme maintenance',
      'Replaced Rebuy with custom dev',
      'CRO & UI improvements',
    ],
    url: 'https://aviatornation.com',
    logoFile: 'aviator-nation.avif',
    screenshotFile: 'aviatornation.com.avif',
  },
  {
    client: 'Sunday Golf',
    type: 'Shopify · Theme Customization',
    work: [
      'Theme customizations',
      'UX & CRO improvements',
    ],
    url: 'https://sundaygolf.com',
    logoFile: 'sunday-golf.avif',
    screenshotFile: 'sundaygolf.com.avif',
  },
  {
    client: 'Paravel',
    type: 'Shopify · Custom Features',
    work: [
      'Theme customizations',
      'Custom product tag feature',
      'Bug fixes',
    ],
    // Site no longer live — no screenshot available, logo-only
    logoFile: 'paravel.avif',
    noScreenshot: true,
  },
  {
    client: 'Rainier Watch',
    type: 'Shopify · Custom Development',
    work: [
      'Custom backorder feature',
      'Low stock FOMO indicators',
      'Theme customization',
    ],
    url: 'https://shop.rainierwatch.com',
    logoFile: 'rainier-watch.avif',
    screenshotFile: 'rainierwatch.com.avif',
  },
  {
    client: 'Revolution Fibers',
    type: 'Shopify · UX Optimization',
    work: [
      'Custom variant selector',
      'UX & conversion improvements',
    ],
    url: 'https://x.com/austriker27/status/1757889669231255935',
    logoFile: 'revolution-fibers.avif',
    screenshotFile: 'revolutionfibers.com.avif',
  },
  {
    client: 'Live Like the Mountain Is Out',
    type: 'Shopify · Full Build',
    work: [
      'Rapid storefront build',
      'On-brand theme customization',
      'CRO features',
    ],
    // Site no longer live — no screenshot available, logo-only
    logoFile: 'south-sound-proud.svg',
    noScreenshot: true,
  },
];
---

<section id="work" class="bg-white">
  <div class="max-w-site mx-auto px-6 md:px-12 py-20 md:py-28">

    <p
      class="text-[11px] font-semibold text-forest tracking-[0.12em] uppercase mb-3"
      data-sal="fade-up"
      data-sal-duration="500"
    >
      Work
    </p>
    <h2
      class="font-serif text-[30px] md:text-[52px] leading-[1.1] mb-10"
      data-sal="fade-up"
      data-sal-duration="500"
      data-sal-delay="80"
    >
      Selected Projects
    </h2>

    <!-- Editorial project list — full-width rows with hairline separators -->
    <div class="border-b border-forest/[0.15]">
      {projects.map((project, i) => {
        const screenshotSrc = project.noScreenshot || !project.screenshotFile
          ? null
          : `/images/screenshots/${project.screenshotFile}`;
        const localLogoSrc = `/images/logos/${project.logoFile}`;
        const Tag = project.url ? 'a' : 'div';
        const linkProps = project.url
          ? { href: project.url, target: '_blank', rel: 'noopener noreferrer' }
          : {};

        return (
          <Tag
            {...linkProps}
            class="group border-t border-forest/[0.15] -mx-6 md:-mx-12 px-6 md:px-12 py-6 md:py-10 flex flex-col md:flex-row gap-4 md:gap-10 md:items-center hover:bg-forest-pale/30 transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-forest focus-visible:ring-offset-2"
            data-sal="fade-up"
            data-sal-duration="500"
            data-sal-delay={String(i * 80)}
          >

            {/* Thumbnail — full-width on mobile (stacks above content), 180px column on desktop */}
            <div class="w-full md:w-[180px] md:flex-shrink-0 order-first md:order-last">
              <div class="aspect-[16/10] rounded-lg overflow-hidden bg-gradient-to-br from-ui-subtle to-ui-placeholder relative">

                {/* Screenshot — wipes in left→right on desktop hover; shows by default on touch */}
                {screenshotSrc && (
                  <img
                    src={screenshotSrc}
                    alt={`${project.client} website`}
                    class="work-screenshot absolute inset-0 w-full h-full object-cover object-top"
                    loading="lazy"
                    width="360"
                    height="225"
                    onerror="this.style.display='none'; this.nextElementSibling.classList.remove('group-hover:opacity-0');"
                  />
                )}

                {/* Logo — fades out on desktop hover if screenshot exists */}
                <div class={`absolute inset-0 flex items-center justify-center ${screenshotSrc ? 'logo-fade group-hover:opacity-0' : ''}`}>
                  <img
                    src={localLogoSrc}
                    alt={`${project.client} logo`}
                    class="max-w-[120px] max-h-[44px] w-auto object-contain"
                    loading="lazy"
                    width="120"
                    height="44"
                    onerror="this.onerror=null; this.style.display='none'; this.nextElementSibling.style.display='block';"
                  />
                  {/* Text fallback if logo image fails */}
                  <span class="font-serif text-sm text-forest/40 hidden">
                    {project.client}
                  </span>
                </div>

              </div>
            </div>

            {/* Index + Main content — side by side */}
            <div class="flex gap-6 md:gap-10 items-start flex-1 min-w-0">

              {/* Index number — counts up from 00 as row enters view */}
              <div class="flex-shrink-0 w-6 md:w-8 pt-1 hidden sm:block">
                <span
                  class="text-[11px] font-semibold tracking-[0.14em] uppercase text-forest/40 group-hover:text-forest transition-colors duration-200 tabular-nums"
                  data-work-index={i + 1}
                >
                  00
                </span>
              </div>

              {/* Main content */}
              <div class="flex-1 min-w-0">

                {/* Client name + project type */}
                <div class="flex flex-wrap items-baseline justify-between gap-x-8 gap-y-2 mb-3">
                  <h3 class="font-serif text-[22px] md:text-[34px] leading-[1.08] tracking-[-0.02em] group-hover:text-forest transition-colors duration-200">
                    {project.client}
                  </h3>
                  <span class="text-[11px] font-semibold tracking-[0.08em] uppercase text-ui-muted flex-shrink-0">
                    {project.type}
                  </span>
                </div>

                {/* Work tags */}
                <div class="flex flex-wrap gap-2">
                  {project.work.map((item) => (
                    <span class="inline-flex items-center text-[11px] font-medium bg-forest-pale text-forest border border-forest/[0.15] rounded-full px-2.5 py-1">
                      {item}
                    </span>
                  ))}
                  {!project.url && (
                    <span class="inline-flex items-center text-[11px] font-medium border border-ui-border text-ui-muted rounded-full px-2.5 py-1">
                      Archived
                    </span>
                  )}
                </div>

              </div>

            </div>

          </Tag>
        );
      })}
    </div>

  </div>
</section>

<style>
  /* Direction A: Clip-path wipe for screenshot reveal.
     Screenshot starts fully clipped from the right, wipes left→right on hover.
     Synced with logo opacity fade (both 220ms ease-out-quart). */
  .work-screenshot {
    clip-path: inset(0 100% 0 0);
    transition: clip-path 220ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  :global(.group:hover) .work-screenshot {
    clip-path: inset(0 0% 0 0);
  }

  @media (prefers-reduced-motion: reduce) {
    .work-screenshot {
      clip-path: inset(0 0% 0 0);
      transition: none;
    }
  }

  /* Touch devices have no hover — show screenshot by default and
     layer it above the logo so both don't overlap awkwardly. */
  @media (hover: none) {
    .work-screenshot {
      clip-path: inset(0 0% 0 0);
      transition: none;
      z-index: 1;
    }
  }

  /* Gate the clip-path wipe to pointer-capable devices only */
  @media not (hover: hover) {
    :global(.group:hover) .work-screenshot {
      clip-path: inset(0 100% 0 0);
    }
  }

  /* Logo fade — opacity transition when screenshot wipes in on hover */
  .logo-fade {
    transition: opacity 220ms cubic-bezier(0.23, 1, 0.32, 1);
  }
  @media (prefers-reduced-motion: reduce) {
    .logo-fade { transition: none; }
  }
</style>

<script>
  // Direction C: Index counter animation.
  // Numbers start at 00 (hidden under sal.js fade-up),
  // count up to their target value as each row enters the viewport.
  (function () {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const spans = document.querySelectorAll<HTMLElement>('[data-work-index]');

    const fmt = (n: number) => n < 10 ? `0${n}` : `${n}`;

    function showFinal(span: HTMLElement) {
      span.textContent = fmt(parseInt(span.dataset.workIndex!, 10));
    }

    function runCounter(span: HTMLElement) {
      const target = parseInt(span.dataset.workIndex!, 10);
      let current = 0;
      const tick = setInterval(() => {
        current++;
        span.textContent = fmt(current);
        if (current >= target) clearInterval(tick);
      }, 35);
    }

    // Reduced motion: show final values immediately, skip animation
    if (prefersReducedMotion) {
      spans.forEach(showFinal);
      return;
    }

    // IntersectionObserver not available: show final values
    if (!('IntersectionObserver' in window)) {
      spans.forEach(showFinal);
      return;
    }

    let remaining = spans.length;
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          observer.unobserve(entry.target);
          runCounter(entry.target as HTMLElement);
          if (--remaining === 0) observer.disconnect();
        });
      },
      { threshold: 0.2 }
    );

    spans.forEach((span) => observer.observe(span));
  })();
</script>
