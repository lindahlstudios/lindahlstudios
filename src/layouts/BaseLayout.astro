---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Lindahl Studios — Boutique Shopify Development',
  description = 'Boutique Shopify development studio. Custom builds, CRO-focused UI/UX, and ecommerce strategy from a US-based team with more than a decade of experience.',
} = Astro.props;

const siteUrl = 'https://lindahlstudios.com';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={`${siteUrl}/og.png`} />
    <meta property="og:site_name" content="Lindahl Studios" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- sal.js CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sal.js@0.8.5/dist/sal.css" />

    <!-- Fathom Analytics -->
    <script src="https://cdn.usefathom.com/script.js" data-site="VBHDNUFW" defer></script>
  </head>
  <body>
    <a
      href="#content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-forest focus:text-white focus:text-sm focus:font-semibold focus:rounded-lg focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-forest"
    >
      Skip to content
    </a>
    <slot />

    <!-- sal.js -->
    <script>
      import sal from 'sal.js';
      sal({
        threshold: 0.2,
        rootMargin: '0px 0px -80px 0px',
        once: true,
      });
    </script>
  </body>
</html>
